# Configuration de test avec SQLite
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=:memory:
DB_DIALECT=sqlite

# Configuration JWT pour tests
JWT_SECRET=test_secret_key_for_testing_only
JWT_EXPIRES_IN=1h

# Configuration du serveur de test
PORT=8081
NODE_ENV=test

# Configuration Frontend pour tests
FRONTEND_URL=http://localhost:4200

# Désactiver les services externes en test
SENDGRID_API_KEY=
SENDGRID_VERIFIED_SENDER=test@example.com
GOOGLE_AI_API_KEY=

# Configuration de test
AUTO_SEED=true
LOG_LEVEL=error